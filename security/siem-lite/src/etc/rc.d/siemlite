#!/bin/sh

# SIEM-Lite RC script for OPNsense
# Manages the siemlite_engine daemon

. /etc/rc.subr

name="siemlite"
rcvar="siemlite_enable"
pidfile="/var/run/siemlite.pid"
command="/usr/local/opnsense/scripts/OPNsense/SIEMLite/siemlite_engine.py"
command_args="daemon &"
command_interpreter="/usr/local/bin/python3"

start_precmd="siemlite_prestart"
stop_postcmd="siemlite_poststop"

siemlite_prestart()
{
    mkdir -p /var/log/siemlite
    mkdir -p /var/db/siemlite
    mkdir -p /usr/local/etc/siemlite
    /usr/local/sbin/configctl template reload OPNsense/SIEMLite
}

siemlite_poststop()
{
    rm -f ${pidfile}
}

load_rc_config $name
run_rc_command "$1"
