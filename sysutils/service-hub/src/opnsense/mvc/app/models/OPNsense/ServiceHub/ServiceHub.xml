<?xml version="1.0"?>
<model>
    <mount>//OPNsense/ServiceHub</mount>
    <version>1.0.0</version>
    <description>Services Hub category configuration</description>
    <items>
        <hub>
            <!-- JSON object mapping plugin id -> category name -->
            <assignments type="TextField">
                <Default>{}</Default>
                <MaximumLength>65535</MaximumLength>
            </assignments>
            <!-- JSON array of category names in display order -->
            <categories type="TextField">
                <Default>["VPN &amp; Tunneling","Network &amp; Proxy","Security","Monitoring","DNS &amp; DHCP","Mail","Backup","System","Other"]</Default>
                <MaximumLength>4096</MaximumLength>
            </categories>
            <!-- Whether hub-only mode is active (hides Services menu items via JS) -->
            <hubOnly type="TextField">
                <Default>0</Default>
                <MaximumLength>1</MaximumLength>
            </hubOnly>
            <!-- Theme name saved before hide-menu was activated, used to restore on disable -->
            <previousTheme type="TextField">
                <Default>opnsense</Default>
                <MaximumLength>64</MaximumLength>
            </previousTheme>
        </hub>
    </items>
</model>
